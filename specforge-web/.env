# Database Credentials for Postgres (Langfuse metadata storage)
DB_USER=langfuse
DB_PASSWORD=langfuse
DB_NAME=langfuse
DB_PORT=5433

# Langfuse Encryption and Auth Secrets
NEXTAUTH_SECRET=specforge-local-dev-secret
SALT=specforge-local-dev-salt

# Langfuse Initial Project Seeding Keys
LANGFUSE_PUBLIC_KEY=pk-lf-local-dev
LANGFUSE_SECRET_KEY=sk-lf-local-dev
LANGFUSE_HOST=http://langfuse:3000

# Langfuse Initial Admin Account
ADMIN_EMAIL=admin@local.dev
ADMIN_PASSWORD=password
ADMIN_NAME=Admin

# Ports configuration
BACKEND_PORT=8000
FRONTEND_PORT=5174

# Specforge Paths (mounted inside docker, relative from host)
SPECFORGE_MODULE_PATH=../specforge-module
WORKSPACE_ROOT=./workspace
